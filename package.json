{
  "name": "offerte-wijs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/generate-sitemap.mjs",
    "build:pages": "GITHUB_PAGES=true npm run build",
    "setup:uptimerobot": "node scripts/setup-uptimerobot-agent.mjs",
    "setup:gsc": "bash scripts/open-gsc-setup.sh",
    "sync:maarten": "node scripts/sync-maarten-wachtrij.mjs",
    "kpi:snapshot": "node scripts/kpi-snapshot.mjs",
    "autopilot": "node scripts/autopilot-run.mjs",
    "scan": "node scripts/security-scan/run.mjs",
    "scan:batch": "node scripts/security-scan/batch.mjs",
    "scan:leaks": "node scripts/security-scan/batch.mjs --mode=leaks",
    "scan:import": "node scripts/security-scan/import-queue.mjs",
    "lead:hunt": "node scripts/lead-hunter/run.mjs",
    "lead:osm": "node scripts/lead-hunter/osm-fetch.mjs",
    "agent:leads": "node scripts/lead-hunter/agent-run.mjs",
    "agent:outreach": "node scripts/outreach-agent/run.mjs",
    "agent:manager": "node scripts/manager-agent/run.mjs",
    "agent:manager:run": "node scripts/manager-agent/run.mjs --execute",
    "agent:pipeline": "npm run agent:leads && npm run scan:leaks && npm run agent:outreach && npm run agent:manager",
    "maarten": "git pull --rebase && npm run sync:maarten",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
